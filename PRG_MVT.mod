  !========================
  ! Calcul de code interne
  !========================
  LOCAL FUNC num Code_Interne()
    ! Calculer le code a executer
    ! en fonction des conditions
    ! internes et retourner
    ! le code calcule
    !
    ! Ex: return XXX
    ! Si pas de code interne
    RETURN 0;
  ENDFUNC

  !=======================
  ! Gestion des programmes
  !=======================
  PROC Programme(
    num prog)

  	!Option Securité
		IF EPSRequest THEN
			AutoriseTraj;
			T_TrajSYNC;
		ENDIF
		!
    TEST prog
    CASE 21:
      Aff_Prog prog,"X62E1H1";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E1H1;
    CASE 23:
      Aff_Prog prog,"X62E2H2";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E2H2;
    CASE 25:
      Aff_Prog prog,"X62E3H2";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E3H2;
    CASE 26:
      Aff_Prog prog,"X62CC";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62CC;
    CASE 27:
      Aff_Prog prog,"X62E3H2B";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E3H2B;
    CASE 53:
      Aff_Prog prog,"T_CHELM_P1";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_CHELM_P1;
      !
      !MOD AMBULANCIA
      !
    CASE 30:
      Aff_Prog prog,"T_XDF_L2H1";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      !T_XDF_L2H1;
    CASE 31:
      Aff_Prog prog,"T_XDF_L2H2";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_XDF_L2H2;
      !
    CASE 124:
      Aff_Prog prog,"X62E1H1AMB";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E1H1;
    CASE 125:
      Aff_Prog prog,"X62E2H2AMB";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E2H2;
    CASE 126:
      Aff_Prog prog,"X62E3H2AMB";
      ! pulse sur la sortie Acquittement code
      PulseDO\PLength:=1,ACQ_CODE1;
      AutoriseTraj;
      T_X62E3H2;
      !
      !Enlever les commentaires pour l'option Changeur Outil
!    CASE 200:
!      Aff_Prog prog,"Chg Toute Electrode";
!      ! pulse sur la sortie Acquittement code
!      PulseDO\PLength:=1,ACQ_CODE1;
!      AutoriseTraj;
!      T_Serv1_ALL;
    !
    ! ne pas modifier la fin de la routine
    !
    
    
    CASE CP_CODE_NUL:
      Aff_Prog 0,strEMPTY;
      Aff_Traj strEMPTY;
    DEFAULT:
      Aff_Prog prog,strEMPTY;
      Aff_Traj strEMPTY;
    ENDTEST
  ENDPROC

  !-----------------------
  ! Procédures de Service
  !-----------------------
  PROC Services(
    num sprog)
    TEST sprog
    CASE CP_DemServ1:
      Aff_Prog sprog,"Chg_Elec";
      AutoriseTraj;
      T_Serv1;
      Etat_Serv1:=EtatService1{noThisTask};
    CASE CP_DemServ2:
      Aff_Prog sprog,"Rodage";
      AutoriseTraj;
      T_Serv2;
      Etat_Serv2:=EtatService2{noThisTask};
    CASE CP_DemServ3:
      Aff_Prog sprog,"Verifier";
      AutoriseTraj;
      T_Serv3;
      Etat_Serv3:=SV_PAS_DEMANDE;
    CASE CP_DemServ4:
      Aff_Prog sprog,"Manutencao";
      AutoriseTraj;
      T_Serv4;
      Etat_Serv4:=SV_PAS_DEMANDE;
    DEFAULT:
    ! ajouter par un ERRWRITE
    ENDTEST
  ENDPROC

