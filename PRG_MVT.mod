  !--------------------------
  ! Trajectoire de lancement
  !--------------------------
  PROC T_Lance()
    Aff_Traj "Lance";
    AntiReboucle;
    !
    MoveJ p_repli,V_moyen,Z_arret,Tool_defaut;
    !
    ! O9:segurança traseira com K1
    ! O12:fora de interferencia1 com K5
    ! O13:fora de interferencia2 com K5
    ORDRE\O9\O12\O13;
    !
    MoveL [[438.93,-1578.56,-395.13],[0.00177362,-0.640935,-0.767576,0.00518556],[-1,-1,0,0],[72.8978,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_defaut;
    MoveL [[607.59,-1578.56,937.89],[0.00103662,-0.741078,-0.671396,0.00538228],[-1,-1,0,0],[152.971,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_defaut;
    MoveJ p_reb_prg, V_moyen, Z_arret, Tool_defaut;
    !
    T_SEGURANCATRASEIRA;
    !
    SR_INIT_PINCE 1;
    !
  ENDPROC

