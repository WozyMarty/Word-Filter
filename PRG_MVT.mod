  !------------
  PROC T_Chela1()
    Aff_Traj "T_Chela1";
    AntiReboucle;
    ! Traj chgt auto Tool_Pince 1
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !SR_CHANGEUR_AUTO 1\CPPEI\CPPES\SM\OUVRE;
    !Traj Approche Changeur
    SR_CEAU 1;
    !SR_RECAL_PINCE\CORR_ELEC1,[[-49.1,196.04,-129.7],[0.703563,0.00097,-0.000327,-0.710633],[1,-2,-3,1],[109,9E+09,9E+09,9E+09,9E+09,9E+09]],1,V_lent,Z_arret,Tool_Pince1,wobj0;
    !Traj Approche Extracteur
    !MoveL Arret sur point d'extraction
    !SR_CHANGEUR_AUTO 1\SM\FERME;
    !Traj Degagement Extracteur
    !MoveL Arret sur point de controle extraction
    !SR_CHANGEUR_AUTO 1\CPPEI\CPPES\SM\OUVRE;
    !Traj approche Mise
    !MoveL Arret sur point de mise electrode
    !SR_SERRER 1,250,0\Temps:=2;
    !Traj Degagement Mise
    !SR_SERRER 1,250,0\Temps:=2;
    !Traj Approche Extracteur
    !SR_RECAL_PINCE\CORR_ELEC2,[[-49.1,196.04,-129.7],[0.703563,0.00097,-0.000327,-0.710633],[1,-2,-3,1],[109,9E+09,9E+09,9E+09,9E+09,9E+09]],1,V_lent,Z_arret,Tool_Pince1,wobj0;
    !MoveL Arret sur point d'extraction
    !SR_CHANGEUR_AUTO 1\SM\FERME;
    !Traj Degagement Extracteur
    !MoveL Arret sur point de controle extraction
    !SR_CHANGEUR_AUTO 1\CPPEI\CPPES\SM\OUVRE;
    !Traj approche Mise
    !MoveL Arret sur point de mise electrode
    !SR_SERRER 1,250,0\Temps:=2;
    !Traj Degagement Mise
    !SR_RECAL_PINCE\SANS_CORR,[[-49.1,196.04,-129.7],[0.703563,0.00097,-0.000327,-0.710633],[1,-2,-3,1],[109,9E+09,9E+09,9E+09,9E+09,9E+09]],1,V_lent,Z_arret,Tool_Pince1,wobj0;
    !SR_SERRER 1,250,0\Temps:=2;
    !SR_CHELAUTO 1;
    !SR_CEAU 0;
    ! trajectoire dégagement
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    SR_INIT_PINCE 1;
    SR_SOUDER p_reb_prg,V_moyen,1,31,Tool_defaut,wobj0;
  ENDPROC

