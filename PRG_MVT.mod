  PROC T_ROD_P1()
    Aff_Traj "T_ROD_P1";
    AntiReboucle;
    ! Traj rodage Séquenceur 1 pince 1
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    SR_RODER 1,141;
    ! trajectoire dégagement
    SR_INIT_PINCE 1;
    SR_SOUDER p_reb_prg, V_moyen, 1,151, Tool_defaut, wobj0;
  ENDPROC

