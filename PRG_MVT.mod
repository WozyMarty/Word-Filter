  PROC T_SEGURANCATRASEIRA()
    toolAtual := CTool();
    wobjAtual := CWObj();
    !
    MoveJ CRobT(), V_moyen, Z_arret, toolAtual\WObj:=wobjAtual;
    ! O9:segurança traseira com K1
    ! O12:fora de interferencia1 com K5
    ! O13:fora de interferencia2 com K5
    ORDRE\O9\O12\O13;
    !    
  ENDPROC
  
  !------------
  PROC T_AUTORIZA_RECUO()
    toolAtual := CTool();
    wobjAtual := CWObj();
