!************************** Trajectoires pour changeur d'outils *******************************

  PROC T_RODCYCLE_P1()
    Aff_Traj "T_RODCYCLE_P1";
    AntiReboucle;
    ! 
    ! Traj rodage Séquenceur 1 pince 1
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    MoveL [[331.05,-2668.97,-882.88],[0.675747,-0.00563673,0.0008286,-0.737112],[-1,-1,0,0],[137.124,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_Pince1;
    MoveL [[329.67,-2817.33,-882.92],[0.675727,-0.00563172,0.000837921,-0.73713],[-1,-1,0,0],[137.124,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_Pince1;
    MoveL pFresaPinca1, V_moyen, Z_arret, Tool_Pince1;
    ! 
    SR_RODER 1,1;
    ! 
    MoveL [[329.67,-2817.33,-882.92],[0.675727,-0.00563172,0.000837921,-0.73713],[-1,-1,0,0],[137.124,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_Pince1;
    MoveL [[331.05,-2668.97,-882.88],[0.675747,-0.00563673,0.0008286,-0.737112],[-1,-1,0,0],[137.124,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_Pince1;
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    ! 
    SR_INIT_PINCE 1;
    SR_SOUDER p_repli, V_moyen, 1, 255, Tool_defaut, wobj0;
    !
  ENDPROC

