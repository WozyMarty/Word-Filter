  PROC T_ROD_1()
    Aff_Traj "T_ROD_1";
    AntiReboucle;
    !
    ! Home Position
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !
    AutoriseTraj;
    T_Repli;
    !
    AutoriseTraj;
    T_RODCYCLE_P1;
    !
    AutoriseTraj;
    T_Lance;
    !
  ENDPROC

  !------------
  PROC T_ROD_2()
    Aff_Traj "T_ROD_2";
    AntiReboucle;
    ! Traj rodage Séquenceur 2 pince 2
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    ! Trajectoire approche
    ! SR_RODER 2,2;
    ! trajectoire dégagement
    SR_INIT_PINCE 0\no_pince2:=2;
    SR_SOUDER p_reb_prg,V_moyen,0,31\no_pince2:=2\prg_soud2:=32,Tool_defaut,wobj0;
  ENDPROC

  !------------
  PROC T_ROD_12()
    Aff_Traj "T_ROD_12";
    AntiReboucle;
    ! Traj rodage séquenceurs 1 et 2 pinces 1 et 2
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    ! Trajectoire approche
    SR_RODER 1,1;
    ! Trajectoire approche
    SR_RODER 2,2;
    ! trajectoire dégagement
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    SR_INIT_PINCE 1\no_pince2:=2;
    SR_SOUDER p_reb_prg,V_moyen,1,31\no_pince2:=2\prg_soud2:=32,Tool_defaut,wobj0;
  ENDPROC

  !------------
  !Mettre en commentaires la routine pour l'option Changeur Outil
  PROC T_Chelm1()
    Aff_Traj "T_Chelm1";
    AntiReboucle;
    !
    ! Home Position
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !
    AutoriseTraj;
    T_Repli;
    !
    AutoriseTraj;
    T_RODCYCLE_P1;
    !
    ! Trajectoire approche
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    SR_CEAU 1;
    MoveL pTrocaEletrodosPinca1, V_moyen, Z_arret, Tool_Pince1;
    !
    ! O9:segurança traseira com K1
    ! O12:fora de interferencia1 com K5
    ! O13:fora de interferencia2 com K5
    ! O15:Sinalizacao de Troca de Eletrodo
    ORDRE\O9\O12\O13\O15;
    !
    !E15:autorizaçăo de recuo troca de eletrodos pinca 1
    EVENT\E15;
    SR_CHELAUTO 1;
    SR_CEAU 0;
    !
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    SR_INIT_PINCE 1;
    SR_SOUDER p_repli,V_moyen,1,255,Tool_defaut,wobj0;
    !
    AutoriseTraj;
    T_RODCYCLE_P1;
    !
    AutoriseTraj;
    T_Lance;
    !
  ENDPROC

