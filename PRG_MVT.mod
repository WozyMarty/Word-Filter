  !------------
  PROC T_Verificar_P1()
    Aff_Traj "T_Verificar_P1";
    AntiReboucle;
    !
    !Home Position
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !
    AutoriseTraj;
    T_Repli;
    !
    ! Traj Verificacao Pinca 1
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    MoveJ [[117.15,-2672.79,-820.13],[0.578822,-0.00575543,0.000189017,-0.815433],[-1,-1,0,0],[72.8969,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_Xlarge, Tool_Pince1;
    MoveL pReferenciaPinca1, V_lent, Z_arret, Tool_Pince1;
    !
    T_Mensagem;
    !
    MoveL [[117.15,-2672.79,-820.13],[0.578822,-0.00575565,0.000188069,-0.815433],[-1,-1,0,0],[72.8966,9E+09,9E+09,9E+09,9E+09,9E+09]], V_lent, Z_Xlarge, Tool_Pince1;
    MoveL [[615.94,-2670.60,-863.81],[0.761828,-0.00559545,0.00156093,-0.647753],[-1,-1,0,0],[72.8897,9E+09,9E+09,9E+09,9E+09,9E+09]], V_lent, Z_Xlarge, Tool_Pince1;
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    !
    AutoriseTraj;
    T_Lance;
    !
  ENDPROC

	!-----------
	PROC T_Mensagem()
		!
		VAR btnres btnMensagem:=0;
		VAR string strMensagem {7}:=[
		"Vire a chave para FS (Fora de servico).",
		"Abra a porta da celula.",
		"Verifique a ferramenta.",
		"Apos a verificacao, feche a porta.",
		"Vire a chave para ES (Em Servico)",
		"Pressione o botao MARCHA CICLO no painel.",
		"Pressione OK abaixo para confirmar."];
		!
		btnMensagem := UIMessageBox(\Header:="       Verificacao de Ferramenta"\MsgArray:=strMensagem\Buttons:=btnOK\Icon:=iconInfo);
  ENDPROC

  !------------
  !Option Securité
  PROC T_TrajSYNC()
  	!
		Aff_Traj "TrajSYNC";
		AntiReboucle;
		!
    !
    !Home Position
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !
    AutoriseTraj;
    T_Repli;
    !
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    MoveJ [[482.36,-1628.63,-396.89],[0.000391776,-0.815436,-0.578822,0.00546986],[-1,-1,0,0],[72.8969,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_Xlarge, Tool_defaut;
    MoveAbsJ pPSync,V_moyen,Z_arret,Tool_defaut;
    !
    SoftwareSync;
    IF diEPS_Sync =1 EPSRequest:=FALSE;
    !
    MoveL [[482.36,-1628.63,-396.89],[0.000391776,-0.815436,-0.578822,0.00546986],[-1,-1,0,0],[72.8969,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_Xlarge, Tool_defaut;
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
    !
    AutoriseTraj;
    T_Lance;
    !
	ENDPROC

  !-------------------------
  ! Trajectoires de Travail
  !-------------------------

  !-------------
  PROC T_X62E1H1()
    VAR bool bStatus;

    Aff_Traj "T_X62E1H1";
    AntiReboucle;
    !
    !Home Position
    MoveJ p_reb_prg,V_rapide,Z_arret,Tool_defaut\WObj:=wobj0;
    !
    T_SEGURANCATRASEIRA;
    !
    ! E1:autorizaçăo de solda 1
    ! O12:fora de interferencia1 com K5
    ! O13:fora de interferencia2 com K5
    EVENT\E1;
    ORDRE\O12\O13;
		!
    AutoriseTraj;
    EVENT\E4;
    T_X62K3E1H1;
    !
    ! O1:fim de solda 1
    ! O12:fora de interferencia1 com K5
    ORDRE\O1\O12;
    !
    ! E2:autorizaçăo de solda 2
    ! O12:fora de interferencia1 com K5
    EVENT\E2;
    ORDRE\O12;
    !
    AutoriseTraj;
    T_X62K3E1H1_OP;
    !
