    AntiReboucle;
    !
    MoveJ p_reb_prg,V_moyen,Z_arret,Tool_defaut;
    !
    T_SEGURANCATRASEIRA;
    !
    MoveL [[607.59,-1578.56,937.88],[0.00103673,-0.741078,-0.671396,0.00538257],[-1,-1,0,0],[152.971,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_defaut;
    MoveL [[438.93,-1578.56,-395.13],[0.00177362,-0.640935,-0.767576,0.00518556],[-1,-1,0,0],[72.8978,9E+09,9E+09,9E+09,9E+09,9E+09]], V_moyen, Z_moyen, Tool_defaut;
    MoveJ p_repli, V_moyen, Z_arret, Tool_defaut;
